# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
# If you have access to a Gemini 3 Flash preview, override GOOGLE_MODEL accordingly.

# OpenAI-compatible (example: NVIDIA NIM)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_COMPATIBLE_MODEL=minimaxai/minimax-m2.5

# Sandbox
E2B_API_KEY=
BYTECODE_E2B_TEMPLATE_ID=

# Optional: Exa MCP web search
EXA_API_KEY=
